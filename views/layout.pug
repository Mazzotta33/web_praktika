doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title= title + ' — Справочник сотрудников'
    link(rel="stylesheet" href="/css/style.css")
    script(src="https://code.jquery.com/jquery-3.7.1.min.js")
  body
    nav.navbar
      a.brand(href="/employees") Справочник сотрудников
      if user
        ul.nav-links
          li: a(href="/employees") Сотрудники
          if user.role === 'Администратор' || user.role === 'Модератор'
            li: a(href="/departments") Отделы
            li: a(href="/positions") Должности
          if user.role === 'Администратор'
            li: a(href="/accounts") Пользователи
          li: a(href="/profile") Мой профиль
          li
            form(action="/logout" method="get" style="display:inline")
              button.btn-link(type="submit") Выйти (#{user.login})
    .container
      if success && success.length
        .flash.flash-success
          each msg in success
            p= msg
      if error && error.length
        .flash.flash-error
          each msg in error
            p= msg
      block content
    script(src="/js/app.js")
